@startuml SSD_DUC006_Handle_Dust_Detected
title SSD - DUC-006 Handle Dust Detection Event

actor "Sensor Input" as Sensor
participant "RVC SW Controller" as System
actor "Cleaning Device" as Cleaner

Sensor -> System: reportDustDetected()
activate System
System -> Cleaner: setCleaningPower(increased)

alt obstacle detected during dust response
    Sensor -> System: reportObstacleState(front=true)
    note right of System: Driving follows DUC-002 or DUC-005
    System -> Cleaner: keepCleaningPower(increased)
end
deactivate System
@enduml
