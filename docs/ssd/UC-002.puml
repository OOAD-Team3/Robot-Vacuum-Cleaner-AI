@startuml SSD_UC002_Stop_On_Front_Obstacle
title SSD - UC-002 Stop After Front Obstacle Detection

actor "Sensor Input" as Sensor
participant "RVC SW Controller" as System
actor "Driving Device" as Drive

Sensor -> System: reportObstacleState(front=true)
activate System
System -> Drive: stop()

alt front, left, and right obstacles detected
    Sensor -> System: reportObstacleState(front=true, left=true, right=true)
    note right of System: Continue with UC-005
else dust detected while stopped
    Sensor -> System: reportDustDetected()
    note right of System: Obstacle avoidance remains priority
end
deactivate System
@enduml
