@startuml SSD_UC004_Resume_After_Turn
title SSD - UC-004 Resume Cleaning After Direction Change

actor "Sensor Input" as Sensor
participant "RVC SW Controller" as System
actor "Driving Device" as Drive
actor "Cleaning Device" as Cleaner

Sensor -> System: reportObstacleState(front=false)
activate System
System -> Drive: moveForward()

alt dust response is active
    System -> Cleaner: keepCleaningPower(increased)
else normal cleaning
    System -> Cleaner: setCleaningPower(normal)
end

alt front obstacle detected again
    Sensor -> System: reportObstacleState(front=true)
    note right of System: Continue with UC-003
end
deactivate System
@enduml
